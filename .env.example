# Copy this file to .env.local and add the real private values there.
# Do not put real keys in this example file.

# Public URL used for QR codes, emails and install links.
# Local: http://localhost:3132
# Live: https://portal.violetproject.co.uk
NEXT_PUBLIC_PORTAL_BASE_URL=

GOOGLE_MAPS_API_KEY=
OPENAI_API_KEY=
OPENAI_EMAIL_DRAFT_MODEL=gpt-4.1-mini

# Microsoft 365 / SharePoint runtime connection.
# These identify the shared Violet Project backend. Keep secrets in .env.local only.
