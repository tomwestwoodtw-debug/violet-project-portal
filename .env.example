MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
SHAREPOINT_HOSTNAME=netorgft10925415.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/VioletProjectOffice
